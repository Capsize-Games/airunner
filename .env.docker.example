# ---------------------------------------------------------------------------
# Example environment for the Docker DEV stack (open-core).
#
# Copy the values you need into your local `.env` (which is gitignored). The
# compose file reads `.env`. Values under "compose" configure the containers;
# values under "app" are passed through to the server.
# ---------------------------------------------------------------------------

# ---- compose: database container ----
POSTGRES_USER=airunner
POSTGRES_PASSWORD=airunner
POSTGRES_DB=airunner
POSTGRES_PORT=5432

# ---- compose: ports / build ----
AIRUNNER_HTTP_PORT=8080
VITE_PORT=5173
# Extras installed into the dev image. "server" = full local ML/GPU stack.
# Use "core" for a lighter API-only image (no torch).
AIRUNNER_DOCKER_EXTRAS=server
# Host Hugging Face cache mounted into the container (avoids re-downloads).
HF_HOME=~/.cache/huggingface
# Model/data directory ("base path"). Unset = an isolated Docker named volume
# (survives `down`, wiped by `down -v`). Point it at an existing AI Runner home
# to reuse already-downloaded models and keep data on the host (a bind mount is
# never destroyed by Docker teardown). Files the container writes there are
# root-owned by default — see docker/README.md ("Model data & persistence").
# AIRUNNER_DATA_DIR=/home/youruser/.local/share/airunner

# ---- app: deployment ----
AIRUNNER_DEPLOYMENT_MODE=development
DEV_ENV=1

# ---- app: extensions (private; bind-mounted, not baked into the image) ----
AIRUNNER_EXTENSIONS=extensions.auth.config,extensions.fastsearch.config

# ---- app: database (the compose file overrides the host to `db`) ----
AIRUNNER_DB_TENANCY=multi
AIRUNNER_REQUIRE_POSTGRES=1

# ---- app: auth ----
AIRUNNER_JWT_SECRET=dev-secret-change-me
AIRUNNER_INSECURE_NO_AUTH=1

# ---- app: external AI provider keys (used instead of local GPU in prod) ----
# OPENROUTER_API_KEY=
# AIRUNNER_IMAGE_API_KEY=

# ---- fastsearch sidecar ----
FASTSEARCH_BASE_URL=http://127.0.0.1:8001
FASTSEARCH_API_KEY=changeme
