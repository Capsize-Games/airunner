{
  "name": "airunner",
  "version": "6.0.0",
  "description": "AI Runner – Desktop application for local AI inference",
  "author": "Capsize LLC",
  "license": "Apache-2.0",
  "homepage": "https://github.com/Capsize-Games/airunner",
  "main": "main.js",
  "scripts": {
    "dev": "electron .",
    "build:linux": "electron-builder --linux --publish never",
    "build:windows": "electron-builder --win --publish never",
    "build:linux:dir": "electron-builder --linux dir --publish never",
    "build:windows:dir": "electron-builder --win dir --publish never"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "org.capsizegames.airunner",
    "productName": "AI Runner",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources",
        "to": "resources",
        "filter": ["**/*"]
      }
    ],
    "asar": false,
    "asarUnpack": [],
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": ["x64"]
        },
        {
          "target": "deb",
          "arch": ["x64"]
        }
      ],
      "category": "Utility",
      "icon": "../packaging/linux",
      "desktop": "../packaging/linux/airunner.desktop"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "../packaging/windows"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
