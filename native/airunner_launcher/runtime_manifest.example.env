# Example AIRunner runtime manifest for production-style bundles.
#
# All relative paths are resolved relative to this manifest file.
# Required keys:
# - AIRUNNER_PYTHON
#
# Optional keys:
# - AIRUNNER_BUNDLE_ROOT
# - AIRUNNER_PYTHONPATH
# - AIRUNNER_ENTRYPOINT
# - AIRUNNER_LLAMA_SERVER_BIN
# - AIRUNNER_WHISPER_SERVER_BIN
#
# The launcher currently treats AIRUNNER_PYTHON as mandatory and sidecar
# paths as runtime-owned optional hints.

AIRUNNER_BUNDLE_ROOT=..
AIRUNNER_PYTHON=../python/bin/python
AIRUNNER_PYTHONPATH=../app/src
AIRUNNER_ENTRYPOINT=airunner.launcher
AIRUNNER_LLAMA_SERVER_BIN=../bin/llama-server
AIRUNNER_WHISPER_SERVER_BIN=../bin/whisper-server